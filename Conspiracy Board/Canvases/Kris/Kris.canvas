					"fromNode":"ff40d377e4df8c0e",
					"fromSide":"right",
					"toNode":"acportal||97e71e7fd7fb6144||3bbf5bd423f74cc2",
					"toSide":"left",
					"color":"4"
				}
			]
		},
		{
			"id":"c3da14ca338f91ef",
			"type":"text",
			"text":"§ Sup, Pearl?",
			"styleAttributes":{},
			"x":-721,
			"y":-1203,
			"width":260,
			"height":60,
			"color":"4"
		},
		{"id":"b637d816cea66643","type":"file","file":"Conspiracy Board/Events/Media/Kris/krisdreemurrkris/Kris hints at kris_dvina_kris Page.png","x":-580,"y":-1095,"width":400,"height":269,"color":"4"},
		{
			"id":"a8bdf4bd0eb8bf69",
			"type":"text",
			"text":"Linking it to Noelle's blog seems to imply whatever this page is actually about involves both Kris & Noelle.",
			"styleAttributes":{},
			"x":-140,
			"y":-1033,
			"width":260,
			"height":192,
			"color":"1"
		},
		{
			"id":"23e736028fef65b6",
			"type":"text",
			"text":"If the spaces are literally meant to represent each missing character; this cannot be \"ROYAL SCIENCES LLC.\" *However*; assuming the spacing is stylistic...\n\nWHAT IS THAT IMPLYING.",
			"styleAttributes":{},
			"x":-960,
			"y":-2939,
			"width":260,
			"height":215,
			"color":"1"
		}
	],
