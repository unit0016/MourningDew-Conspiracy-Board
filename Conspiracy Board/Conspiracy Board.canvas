		{"id":"89f350bb2e33923d","type":"file","file":"Conspiracy Board/Events/Media/Consultations/RFRX Consultation.png","x":1740,"y":-5795,"width":176,"height":399},
		{"id":"1e5c217dbf7dbbb4","type":"file","file":"Conspiracy Board/Events/Media/Consultations/13B Consultation.png","x":4720,"y":-4757,"width":363,"height":308},
		{"id":"9b0ab82f47ed7e12","type":"file","file":"Conspiracy Board/Events/Media/Consultations/TYPO Consultation.png","x":4700,"y":-5816,"width":197,"height":400},
		{"id":"f343f284f1b31ffe","type":"file","file":"Conspiracy Board/Events/Media/Consultations/YEOO Consultation A1.png","x":2220,"y":-5798,"width":311,"height":400},
		{"id":"79eec9c8221dde40","type":"file","file":"Conspiracy Board/Events/Media/Lake.png","x":1080,"y":-5770,"width":400,"height":300},
		{
			"id":"9261803b06673fc3",
			"type":"text",
			"text":"Coldwater fell from the sky.",
			"styleAttributes":{},
			"x":48,
			"y":-5531,
			"width":260,
			"height":60,
			"color":"6"
		},
		{"id":"027458e69f0f5376","type":"file","file":"Conspiracy Board/Events/Media/Something with Alvin.png","x":1520,"y":-5770,"width":113,"height":212},
		{"id":"469dc88e3342f176","type":"link","url":"https://mourningdew.phinarina.xyz/G7DVlrUSVH244QLHOOQ/","x":150,"y":-5786,"width":140,"height":200},
		{"id":"dd972d834ac4b84c","type":"file","file":"Conspiracy Board/Events/Media/Consultations/14b Consultation (Noelle).png","x":5100,"y":-4754,"width":400,"height":302},
		{"id":"4ffd47874305863a","type":"file","file":"Conspiracy Board/Events/Media/Consultations/Brickman Consultation.md","x":5160,"y":-5796,"width":400,"height":480},
		{"id":"022584a83ab2873b","type":"file","file":"Conspiracy Board/Events/Media/Consultations/bubba Consultation.png","x":4940,"y":-5801,"width":193,"height":400},
		{"id":"097b4ff1107a8cbd","type":"file","file":"Conspiracy Board/Events/Media/Penny Thank You.png","x":-320,"y":-5752,"width":400,"height":132},
		{"id":"163308a7c46e81b7","type":"file","file":"Conspiracy Board/Events/Media/Consultations/17b Consultation.png","x":5520,"y":-4754,"width":420,"height":303},
		{"id":"303ec15895562b6d","type":"file","file":"Conspiracy Board/Events/Media/Consultations/Autumn Consultation A1.png","x":5600,"y":-5796,"width":400,"height":395},
		{
			"id":"b744fe65e02528fb",
			"type":"text",
			"text":"This string of characters is important to some puzzle we haven't quite cottoned onto.",
			"styleAttributes":{},
			"x":104,
			"y":-5960,
			"width":260,
			"height":100,
			"color":"1"
		},
		{
			"id":"00a5442d2054a87a",
			"type":"text",
			"text":"Kris has been depicted wearing a sweater emblazed with the DELTA RUNE; angel crest right on the chest like whoever - whatever, this is. Is it a standardized uniform for the town, or...?",
			"styleAttributes":{},
			"x":474,
			"y":-5960,
			"width":440,
			"height":120,
			"color":"1"
		},
		{
			"id":"ea0b3ee9df14681d",
			"type":"text",
			"text":"What's with this symbolism for Alvin?",
			"styleAttributes":{},
			"x":1373,
			"y":-5930,
			"width":260,
			"height":60,
			"color":"1"
		},
		{"id":"c1eb43247e56e2a9","type":"file","file":"Conspiracy Board/Events/Media/Consultations/Autumn Consultation A2.png","x":5624,"y":-5376,"width":352,"height":400},
		{"id":"c0df7da0adfe5a59","type":"file","file":"Conspiracy Board/Events/Media/Consultations/18b Consultation (Same Email at 9b, But Plus Variant).png","x":5980,"y":-4754,"width":299,"height":400},
		{"id":"2424ac1e48352caf","type":"file","file":"Conspiracy Board/Events/Media/Consultations/Photon Consultation.md","x":6040,"y":-5796,"width":400,"height":480},
